PORT=3002
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# POSTGRES_URL_NON_POOLING=
# DATABASE_URL=
# PG_SSL_REJECT_UNAUTHORIZED=false

# Production: минимум 32 символа, случайная строка (openssl rand -hex 32)
AUTH_SECRET=

# Один origin или несколько через запятую (для своего домена + *.vercel.app)
# На Vercel без переменной берётся https://$VERCEL_URL
CORS_ORIGIN=*

# Доп. хост для TonConnect SignData (без схемы), если сайт на своём домене
# SITE_HOST=degram.example.com

# Домены для ton_proof (и SignData, если включите). Плюс автоматически: localhost, 127.0.0.1, VERCEL_URL, SITE_HOST
TON_PROOF_ALLOWED_DOMAINS=localhost,127.0.0.1
SIGN_DATA_ALLOWED_DOMAINS=localhost,127.0.0.1
SIGN_DATA_MAX_AGE_SEC=900
TON_PROOF_MAX_AGE_SEC=900

# Лимиты запросов в минуту (PostgreSQL rate_limits)
# REQUESTS_PER_MINUTE=300
# HOLDINGS_REQUESTS_PER_MINUTE=60

TONCENTER_API_KEY=
TONCENTER_API_BASE=https://toncenter.com/api/v3
TONCENTER_TIMEOUT_MS=9000
COINGECKO_TON_PRICE_URL=https://api.coingecko.com/api/v3/simple/price?ids=the-open-network&vs_currencies=usd
DYOR_API_KEY=

HOLDINGS_NFT_LIMIT=12
HOLDINGS_JETTON_LIMIT=10
HOLDINGS_DNS_LIMIT=12
